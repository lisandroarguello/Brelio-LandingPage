# ─── Brelio Landing Page — Variables de Entorno ─────────────────────────────
# Copiá este archivo como .env y completá los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ─── Email (Nodemailer / Gmail SMTP) ────────────────────────────────────────
# Para usar Gmail: activá "Verificación en 2 pasos" y creá una "Contraseña de aplicación"
# en: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion

# Email donde recibirás los nuevos leads
MAIL_TO=hola@brelio.com.ar

# ─── Notion CRM ─────────────────────────────────────────────────────────────
# 1. Creá una integración en https://www.notion.so/my-integrations
# 2. Copiá el "Internal Integration Token"
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. Creá una base de datos en Notion con las siguientes columnas:
#    Nombre (Title) | Empresa (Text) | Email (Email) | WhatsApp (Phone)
#    Objetivo (Multi-select) | Problema (Text) | Etapa (Select)
#    Urgencia (Select) | Presupuesto (Select) | Fecha (Date)
# 4. Compartí la base de datos con tu integración (botón "Conectar a")
# 5. Copiá el ID de la base de datos desde la URL:
#    https://notion.so/tu-workspace/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ────────────────────────────────────────────────────────────────────
# URL del sitio en producción (sin slash final)
APP_URL=https://brelio.com.ar
